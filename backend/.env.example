# Admin Authorization Email Alerts
# Comma-separated list of admin recipients
ADMIN_ALERT_EMAILS=admin1@example.com,admin2@example.com

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username@example.com
SMTP_PASSWORD=your-smtp-password-or-app-password

# Optional sender override (defaults to SMTP_USERNAME if empty)
SMTP_FROM_EMAIL=VulnHub Access System <janmesh@gmail.com>

# Optional TLS toggle (true/false). Defaults to true in code.
SMTP_USE_TLS=true
